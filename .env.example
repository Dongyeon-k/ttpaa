CONSTITUTION_OCR_ENABLED=True
CONSTITUTION_OCR_LANG=kor+eng
CONSTITUTION_OCR_DPI=200
CONSTITUTION_OCR_MIN_TEXT_CHARS=20

GOOGLE_SERVICE_ACCOUNT_FILE=/app/secrets/google-service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON=
